# TradeMatrix Environment Variables
# Copy this to .env and fill in your values

# Application
APP_NAME=TradeMatrix
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Database (auto-created in ./database/ folder)
DATABASE_URL=sqlite+aiosqlite:///./database/tradematrix.db

# API CORS Origins (frontend URLs)
# CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Screener Settings
SCREENER_UNIVERSE=NIFTY500
MAX_CONCURRENT_FETCHES=10
FETCH_DELAY_SECONDS=0.3
DATA_PERIOD=2y
DATA_INTERVAL=1d

# Paper Trading Defaults
DEFAULT_CAPITAL=100000.0
DEFAULT_POSITION_SIZE_PCT=0.10
FIXED_SL_PCT=0.05
ATR_SL_MULTIPLIER=2.0
TARGET_RSI_OVERBOUGHT=70.0
TARGET_PROFIT_PCT=0.12
EARNINGS_BLACKOUT_DAYS=3

# Fundamental Thresholds
MIN_ROCE=15.0
MAX_DEBT_TO_EQUITY=1.0
MIN_PIOTROSKI_SCORE=7

# Technical Thresholds
RSI_OVERSOLD=30.0
RSI_PERIOD=14
EMA_LONG_PERIOD=200

# Logging
LOG_LEVEL=INFO
